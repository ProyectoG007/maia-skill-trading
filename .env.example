# MAIA Trading System — variables de entorno
# Copiar a .env y completar. NUNCA commitear .env con valores reales.

# ── Directorio de contexto compartido (Capa 6) ───────────────────
# Debe ser el MISMO path/volumen que usa TradingMY
# (src/context/external_context.py) para leer macro_context.json y
# forecast_<SYMBOL>.json.
MAIA_CONTEXT_DIR=./context_data

# ── Postgres / Supabase (Capa 2) ──────────────────────────────────
# Proyecto ya creado: "maia-trading" (ref xtjffjxzwxxqmhhvlkxd, org
# LogisticAs.Dev, plan free $0/mes), con db/schema.sql ya aplicado.
# Falta un solo paso manual: la contraseña no se puede obtener por API
# por seguridad — andá a Supabase Dashboard -> maia-trading ->
# Project Settings -> Database -> Connection string, copiá la
# contraseña (o generá una nueva) y completá abajo.
# Sin esto, scripts/persist_macro_context.py y TradingMY siguen
# funcionando igual, solo con el archivo compartido (degradación
# elegante) — no es bloqueante para seguir desarrollando.
DATABASE_URL=
# DATABASE_URL=postgresql://postgres:[DB-PASSWORD]@db.xtjffjxzwxxqmhhvlkxd.supabase.co:5432/postgres

# ── Claude API (Capa 7) — usado por el skill Tododeia y por TradeAgent ──
ANTHROPIC_API_KEY=

# ── TimesFM service (services/timesfm/) ──────────────────────────
TIMESFM_SERVICE_PORT=8900

# ── Telegram (Capa 9) — ya usado por TradingMY, documentado aca por referencia ──
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
