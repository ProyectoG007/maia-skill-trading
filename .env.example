# MAIA Trading System — variables de entorno
# Copiar a .env y completar. NUNCA commitear .env con valores reales.

# ── Directorio de contexto compartido (Capa 6) ───────────────────
# Debe ser el MISMO path/volumen que usa TradingMY
# (src/context/external_context.py) para leer macro_context.json y
# forecast_<SYMBOL>.json.
MAIA_CONTEXT_DIR=./context_data

# ── Postgres / Supabase (Capa 2) — opcional en F1, requerido en F2+ ──
# Sin esto, scripts/persist_macro_context.py solo escribe el archivo
# compartido (degradación elegante).
DATABASE_URL=

# ── Claude API (Capa 7) — usado por el skill Tododeia y por TradeAgent ──
ANTHROPIC_API_KEY=

# ── TimesFM service (services/timesfm/) ──────────────────────────
TIMESFM_SERVICE_PORT=8900

# ── Telegram (Capa 9) — ya usado por TradingMY, documentado aca por referencia ──
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
